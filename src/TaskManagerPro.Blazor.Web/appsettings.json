{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_SQL_SERVER_CONNECTION_STRING_HERE"
  },
  "Jwt": {
    "Key": "YOUR_JWT_SECRET_KEY_HERE",
    "Issuer": "TaskManagerPro.Blazor",
    "Audience": "TaskManagerPro.Blazor.Users",
    "ExpirationMinutes": 60
  },
  "SendGrid": {
    "ApiKey": "YOUR_SENDGRID_API_KEY_HERE",
    "FromEmail": "noel.mino.dev@gmail.com",
    "FromName": "TaskManager Pro"
  },
  "EmailVerification": {
    "ExpirationMinutes": "5",
    "BaseUrl": "http://localhost:5026"
  },
  "Cloudinary": {
    "CloudName": "YOUR_CLOUD_NAME_HERE",
    "ApiKey": "YOUR_CLOUDINARY_API_KEY_HERE",
    "ApiSecret": "YOUR_CLOUDINARY_API_SECRET_HERE"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
