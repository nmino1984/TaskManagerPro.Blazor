@inherits LayoutComponentBase
@implements IDisposable
@using System.Security.Claims
@using MediatR
@using TaskManagerPro.Blazor.Application.Features.Notifications.Queries.GetNotifications
@using TaskManagerPro.Blazor.Domain.Enums
@using TaskManagerPro.Blazor.Web.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject AuthService AuthSvc
@inject NotificationCountService NotificationCount
@inject IMediator Mediator
@inject IServiceScopeFactory ScopeFactory

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="false" Color="Color.Dark">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3 app-title">TaskManager Pro</MudText>
        <MudSpacer />
        <MudTooltip Text="Notifications">
            <MudBadge Content="@_unreadCount" Color="Color.Error" Overlap="true" Visible="@(_unreadCount > 0)">
                <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                               Color="Color.Inherit"
                               Href="/notifications" />
            </MudBadge>
        </MudTooltip>
        <MudAvatar Color="Color.Secondary" Size="Size.Small" Class="mr-2">@_initials</MudAvatar>
        <MudText Typo="Typo.body2" Class="mr-2">@_fullName</MudText>
        <MudTooltip Text="Logout">
            <MudIconButton Icon="@Icons.Material.Filled.Logout"
                           Color="Color.Inherit"
                           OnClick="Logout" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="2"
               Variant="DrawerVariant.Persistent"
               Class="drawer-nav">
        <MudDrawerHeader>
            <MudText Typo="Typo.subtitle1" Class="drawer-header-text">Navigation</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private int _unreadCount;
    private string _fullName = string.Empty;
    private string _initials = string.Empty;
    private Guid _userId;

    protected override void OnInitialized()
    {
        NotificationCount.OnCountChanged += OnBadgeCountChanged;
        NavManager.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var firstName = user.FindFirst("given_name")?.Value ?? string.Empty;
            var lastName  = user.FindFirst("family_name")?.Value ?? string.Empty;
            _fullName = $"{firstName} {lastName}".Trim();
            _initials = string.Concat(
                firstName.Length > 0 ? firstName[0..1] : string.Empty,
                lastName.Length > 0  ? lastName[0..1]  : string.Empty);

            var userIdClaim = user.FindFirst("sub")?.Value;
            if (Guid.TryParse(userIdClaim, out var userId))
            {
                _userId = userId;
                await LoadNotificationCountAsync();
            }

            StateHasChanged();
        }
    }

    // Uses its own scope so the DbContext doesn't conflict with the page's concurrent DB operations
    private async Task LoadNotificationCountAsync()
    {
        if (_userId == Guid.Empty) return;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var mediator = scope.ServiceProvider.GetRequiredService<IMediator>();
            var notifications = await mediator.Send(new GetNotificationsQuery(_userId));
            var unread = notifications.Count(n => n.Status == NotificationStatus.Unread);
            NotificationCount.SetCount(unread);
        }
        catch { /* fail silently — badge refreshes on next navigation */ }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ = LoadNotificationCountAsync();
    }

    private void OnBadgeCountChanged()
    {
        _unreadCount = NotificationCount.UnreadCount;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task Logout() => await AuthSvc.LogoutAsync();

    public void Dispose()
    {
        NotificationCount.OnCountChanged -= OnBadgeCountChanged;
        NavManager.LocationChanged -= OnLocationChanged;
    }
}
