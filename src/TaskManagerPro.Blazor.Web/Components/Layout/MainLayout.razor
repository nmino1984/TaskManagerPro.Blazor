@inherits LayoutComponentBase
@implements IDisposable
@using System.Security.Claims
@using MediatR
@using TaskManagerPro.Blazor.Application.Features.Notifications.Queries.GetNotifications
@using TaskManagerPro.Blazor.Application.Features.Auth.Commands.ResendVerificationEmail
@using TaskManagerPro.Blazor.Domain.Enums
@using TaskManagerPro.Blazor.Web.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject AuthService AuthSvc
@inject NotificationCountService NotificationCount
@inject IMediator Mediator
@inject IServiceScopeFactory ScopeFactory

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="false" Color="Color.Dark">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3 app-title">TaskManager Pro</MudText>
        <MudSpacer />
        <MudTooltip Text="Notifications">
            <MudBadge Content="@_unreadCount" Color="Color.Error" Overlap="true" Visible="@(_unreadCount > 0)">
                <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                               Color="Color.Inherit"
                               Href="/notifications" />
            </MudBadge>
        </MudTooltip>
        <MudAvatar Color="Color.Secondary" Size="Size.Small" Class="mr-2">@_initials</MudAvatar>
        <MudLink Href="/profile" Typo="Typo.body2" Color="Color.Inherit" Class="mr-2" Underline="Underline.Hover">@_fullName</MudLink>
        <MudTooltip Text="Logout">
            <MudIconButton Icon="@Icons.Material.Filled.Logout"
                           Color="Color.Inherit"
                           OnClick="Logout" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="2"
               Variant="DrawerVariant.Persistent"
               Class="drawer-nav">
        <MudDrawerHeader>
            <MudText Typo="Typo.subtitle1" Class="drawer-header-text">Navigation</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">
            @if (!_isEmailVerified)
            {
                <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true">
                    Your email address is not verified. Please check your inbox.
                    @if (_resendEmailSent)
                    {
                        <MudText Typo="Typo.body2" Inline="true" Class="ml-2" Style="font-weight:600">Email sent!</MudText>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Warning" Size="Size.Small"
                                   Class="ml-1 pa-0" Style="min-width:0; text-transform:none; font-weight:600"
                                   OnClick="ResendVerificationEmailAsync" Disabled="_resendingEmail">
                            @if (_resendingEmail)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                            }
                            Resend verification email
                        </MudButton>
                    }
                </MudAlert>
            }
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private int _unreadCount;
    private string _fullName = string.Empty;
    private string _initials = string.Empty;
    private Guid _userId;
    private bool _isEmailVerified = true; // default true — banner only shows after auth state loads
    private string _userEmail = string.Empty;
    private bool _resendingEmail;
    private bool _resendEmailSent;

    protected override void OnInitialized()
    {
        NotificationCount.OnCountChanged += OnBadgeCountChanged;
        NavManager.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var firstName = user.FindFirst("given_name")?.Value ?? string.Empty;
            var lastName  = user.FindFirst("family_name")?.Value ?? string.Empty;
            _fullName = $"{firstName} {lastName}".Trim();
            _initials = string.Concat(
                firstName.Length > 0 ? firstName[0..1] : string.Empty,
                lastName.Length > 0  ? lastName[0..1]  : string.Empty);

            _isEmailVerified = user.FindFirst("email_verified")?.Value == "true";
            _userEmail = user.FindFirst("email")?.Value ?? string.Empty;

            var userIdClaim = user.FindFirst("sub")?.Value;
            if (Guid.TryParse(userIdClaim, out var userId))
            {
                _userId = userId;
                await LoadNotificationCountAsync();
            }

            StateHasChanged();
        }
    }

    // Uses its own scope so the DbContext doesn't conflict with the page's concurrent DB operations
    private async Task LoadNotificationCountAsync()
    {
        if (_userId == Guid.Empty) return;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var mediator = scope.ServiceProvider.GetRequiredService<IMediator>();
            var notifications = await mediator.Send(new GetNotificationsQuery(_userId));
            var unread = notifications.Count(n => n.Status == NotificationStatus.Unread);
            NotificationCount.SetCount(unread);
        }
        catch { /* fail silently — badge refreshes on next navigation */ }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ = LoadNotificationCountAsync();
    }

    private void OnBadgeCountChanged()
    {
        _unreadCount = NotificationCount.UnreadCount;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task Logout() => await AuthSvc.LogoutAsync();

    private async Task ResendVerificationEmailAsync()
    {
        if (string.IsNullOrEmpty(_userEmail)) return;

        _resendingEmail = true;
        var result = await Mediator.Send(new ResendVerificationEmailCommand(_userEmail));
        _resendingEmail = false;
        _resendEmailSent = result.Success;
    }

    public void Dispose()
    {
        NotificationCount.OnCountChanged -= OnBadgeCountChanged;
        NavManager.LocationChanged -= OnLocationChanged;
    }
}
