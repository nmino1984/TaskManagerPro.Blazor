@* Navigation menu rendered inside the persistent side drawer. *@
@* Each MudNavLink maps to a top-level section of the application. *@

<MudNavMenu>
    <MudNavLink Href="/"
                Icon="@Icons.Material.Filled.Dashboard"
                IconColor="Color.Primary"
                Match="NavLinkMatch.All">
        Dashboard
    </MudNavLink>

    <MudNavLink Href="/tasks"
                Icon="@Icons.Material.Filled.Assignment"
                IconColor="Color.Primary">
        My Tasks
    </MudNavLink>

    <MudNavLink Href="/milestones"
                Icon="@Icons.Material.Filled.Flag"
                IconColor="Color.Primary">
        Milestones
    </MudNavLink>

    <MudNavLink Href="/notifications"
                Icon="@Icons.Material.Filled.Notifications"
                IconColor="Color.Primary">
        Notifications
    </MudNavLink>
</MudNavMenu>
