@page "/tasks/{Id:guid}"
@rendermode InteractiveServer
@inherits TaskManagerPro.Blazor.Web.Pages.AuthenticatedPageBase

@using MediatR
@using System.Security.Claims
@using TaskManagerPro.Blazor.Application.Features.Tasks.Queries.GetAllTasks
@using TaskManagerPro.Blazor.Application.Features.Tasks.Commands.DeleteTask
@using TaskManagerPro.Blazor.Application.Features.Tasks.Commands.UpdateTask
@using TaskManagerPro.Blazor.Application.Features.SubTasks.Queries.GetSubTasksByTask
@using TaskManagerPro.Blazor.Application.Features.SubTasks.Commands.UpdateSubTask
@using TaskManagerPro.Blazor.Application.Features.SubTasks.Commands.DeleteSubTask
@using TaskManagerPro.Blazor.Application.Features.Milestones.Queries.GetMilestonesByTask
@using TaskManagerPro.Blazor.Application.Features.Milestones.Commands.DeleteMilestone
@using TaskManagerPro.Blazor.Application.Features.Milestones.Commands.UpdateMilestone
@using TaskManagerPro.Blazor.Application.Common.Models
@using TaskManagerPro.Blazor.Domain.Enums

@inject IMediator Mediator
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Task Detail — TaskManager Pro</PageTitle>

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-6" />
}
else if (_task is null)
{
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/tasks" Variant="Variant.Text" Class="mb-4">
        ← Back to Tasks
    </MudButton>
    <MudAlert Severity="Severity.Warning">Task not found or you do not have permission to view it.</MudAlert>
}
else
{
    @* ── Header ── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                   Href="/tasks"
                   Variant="Variant.Text">← Back to Tasks</MudButton>
        <MudStack Row="true" Spacing="2">
            @if (_task.Status != WorkTaskStatus.Completed && _task.Status != WorkTaskStatus.Cancelled)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Edit"
                           OnClick="OpenEditTaskDialogAsync">Edit Task</MudButton>
            }
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="DeleteTaskAsync">Delete Task</MudButton>
        </MudStack>
    </MudStack>

    @* ── Status alerts ── *@
    @if (_task.Status == WorkTaskStatus.Completed)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4">
            ✓ This task has been completed. Create a new task to add more work.
        </MudAlert>
    }
    else if (_task.Status == WorkTaskStatus.Cancelled)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
            <MudAlert Severity="Severity.Warning" Class="mb-0" Style="flex:1">
                This task was cancelled.
            </MudAlert>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Warning"
                       OnClick="ReopenTaskAsync">↺ Reopen Task</MudButton>
        </MudStack>
    }

    @* ── Task info card ── *@
    <MudPaper Elevation="2" Class="pa-6 mb-6">
        <MudText Typo="Typo.h4" Class="mb-3">@_task.Title</MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3" Wrap="Wrap.Wrap">
            <MudChip T="string" Color="@GetPriorityColor(_task.Priority)" Variant="Variant.Filled" Size="Size.Small">
                @_task.Priority
            </MudChip>
            <MudChip T="string" Color="@GetStatusColor(_task.Status)" Variant="Variant.Outlined" Size="Size.Small">
                @FormatStatus(_task.Status)
            </MudChip>
            @if (_task.DueDate.HasValue)
            {
                bool overdue = _task.DueDate.Value.Date < DateTime.UtcNow.Date
                               && _task.Status != WorkTaskStatus.Completed
                               && _task.Status != WorkTaskStatus.Cancelled;
                <MudChip T="string"
                         Color="@(overdue ? Color.Error : Color.Default)"
                         Variant="Variant.Text"
                         Size="Size.Small"
                         Icon="@Icons.Material.Filled.CalendarToday">
                    Due: @_task.DueDate.Value.ToString("MMM dd, yyyy")
                </MudChip>
            }
        </MudStack>
        @if (!string.IsNullOrWhiteSpace(_task.Description))
        {
            <MudText Typo="Typo.body1">@_task.Description</MudText>
        }
    </MudPaper>

    @* ── Subtasks ── *@
    <MudPaper Elevation="2" Class="pa-6 mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
            <MudText Typo="Typo.h6">Subtasks</MudText>
            @if (_task.Status != WorkTaskStatus.Completed && _task.Status != WorkTaskStatus.Cancelled)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           Size="Size.Small"
                           OnClick="OpenAddSubTaskDialogAsync">+ Add Subtask</MudButton>
            }
        </MudStack>

        @if (_subTasks.Any())
        {
            int completedCount = _subTasks.Count(s => s.IsCompleted);
            int totalCount     = _subTasks.Count;
            double progress    = (double)completedCount / totalCount * 100.0;

            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-1">
                @completedCount of @totalCount completed
            </MudText>
            <MudProgressLinear Value="@progress"
                               Color="Color.Success"
                               Rounded="true"
                               Size="Size.Medium"
                               Class="mb-4" />

            @foreach (SubTaskDto subtask in _subTasks)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudCheckBox T="bool"
                                     Value="subtask.IsCompleted"
                                     ValueChanged="@((bool val) => ToggleSubTaskAsync(subtask, val))"
                                     Color="Color.Success" />
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1"
                                     Style="@(subtask.IsCompleted ? "text-decoration:line-through;opacity:0.6" : string.Empty)">
                                @subtask.Title
                            </MudText>
                            @if (!string.IsNullOrWhiteSpace(subtask.Description))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@subtask.Description</MudText>
                            }
                        </MudStack>
                    </MudStack>
                    @if (_task.Status != WorkTaskStatus.Completed)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       aria-label="Delete subtask"
                                       OnClick="() => DeleteSubTaskAsync(subtask)" />
                    }
                </MudStack>
                <MudDivider Class="mb-2" />
            }
        }
        else
        {
            <MudText Color="Color.Secondary">No subtasks yet. Add one to break this task into smaller steps.</MudText>
        }
    </MudPaper>

    @* ── Milestones ── *@
    <MudPaper Elevation="2" Class="pa-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
            <MudText Typo="Typo.h6">Milestones</MudText>
            @if (_task.Status != WorkTaskStatus.Completed && _task.Status != WorkTaskStatus.Cancelled)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           Size="Size.Small"
                           OnClick="OpenAddMilestoneDialogAsync">+ Add Milestone</MudButton>
            }
        </MudStack>

        @if (_milestones.Any())
        {
            @foreach (MilestoneDto milestone in _milestones.OrderBy(m => m.TargetDate))
            {
                <MudCard Elevation="1" Class="mb-3">
                    <MudCardContent>
                        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="1">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.subtitle1" Style="font-weight:600">@milestone.Title</MudText>
                                    <MudChip T="string"
                                             Color="@GetMilestoneStatusColor(milestone.Status)"
                                             Variant="Variant.Filled"
                                             Size="Size.Small">
                                        @milestone.Status
                                    </MudChip>
                                </MudStack>
                                @if (!string.IsNullOrWhiteSpace(milestone.Description))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@milestone.Description</MudText>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Target: @milestone.TargetDate.ToString("MMM dd, yyyy")
                                </MudText>
                            </MudStack>
                            @if (_task.Status != WorkTaskStatus.Completed)
                            {
                                <MudStack Row="true" Spacing="1">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   aria-label="Edit milestone"
                                                   OnClick="() => OpenEditMilestoneDialogAsync(milestone)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   aria-label="Delete milestone"
                                                   OnClick="() => DeleteMilestoneAsync(milestone)" />
                                </MudStack>
                            }
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            }
        }
        else
        {
            <MudText Color="Color.Secondary">No milestones yet. Add one to track key checkpoints.</MudText>
        }
    </MudPaper>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private TaskItemDto?        _task;
    private IList<SubTaskDto>   _subTasks   = new List<SubTaskDto>();
    private IList<MilestoneDto> _milestones = new List<MilestoneDto>();
    private bool _isLoading = true;
    private Guid _userId;

    // OnInitializedAsync runs during SSR where localStorage is inaccessible and "sub" claim is null;
    // firstRender is the first safe point after the Blazor Server circuit is fully connected
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState    = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdString = authState.User.FindFirst("sub")?.Value;

        if (string.IsNullOrEmpty(userIdString) || !Guid.TryParse(userIdString, out Guid userId))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _userId = userId;
        await LoadDataAsync();
        StateHasChanged();
    }

    // _task is set to null when the Id is valid but belongs to a different user (access denied via empty query result)
    private async Task LoadDataAsync()
    {
        _isLoading = true;
        try
        {
            var result = await Mediator.Send(new GetAllTasksQuery(_userId, Page: 1, PageSize: 1000));
            _task = result.Items.FirstOrDefault(t => t.Id == Id);

            if (_task is not null)
            {
                var subTasksResult  = await Mediator.Send(new GetSubTasksByTaskQuery(Id));
                _subTasks = subTasksResult.ToList();

                var milestonesResult = await Mediator.Send(new GetMilestonesByTaskQuery(Id));
                _milestones = milestonesResult.ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // Captures status before the dialog opens so we can detect a Completed transition on close
    // and offer to complete any pending milestones via HandlePendingMilestonesAfterCompletionAsync
    private async Task OpenEditTaskDialogAsync()
    {
        WorkTaskStatus statusBeforeEdit = _task?.Status ?? WorkTaskStatus.Pending;

        var parameters = new DialogParameters<TaskDialog>();
        parameters.Add(d => d.UserId, _userId);
        parameters.Add(d => d.ExistingTask, _task);

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog  = await DialogService.ShowAsync<TaskDialog>("Edit Task", parameters, options);
        var result  = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadDataAsync();
            StateHasChanged();

            if (_task is not null
                && _task.Status == WorkTaskStatus.Completed
                && statusBeforeEdit != WorkTaskStatus.Completed
                && _milestones.Any(m => m.Status != MilestoneStatus.Completed))
            {
                await HandlePendingMilestonesAfterCompletionAsync();
            }
        }
    }

    // Resets task to Pending via domain method, then immediately opens the edit dialog
    // so the user can set a new due date without a separate click
    private async Task ReopenTaskAsync()
    {
        var parameters = new DialogParameters<MudMessageBox>();
        parameters.Add(x => x.Message, "Reopen this task? You will need to set a new due date.");
        parameters.Add(x => x.YesText, "Reopen");
        parameters.Add(x => x.CancelText, "Cancel");

        var dialog = await DialogService.ShowAsync<MudMessageBox>("Reopen Task", parameters);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        try
        {
            await Mediator.Send(new UpdateTaskCommand(
                Id, _task!.Title, _task.Description, _task.DueDate, _task.Priority,
                WorkTaskStatus.Pending));

            await LoadDataAsync();
            await OpenEditTaskDialogAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteTaskAsync()
    {
        var parameters = new DialogParameters<MudMessageBox>();
        parameters.Add(x => x.Message, $"Delete \"{_task!.Title}\"? This action cannot be undone.");
        parameters.Add(x => x.YesText, "Delete");
        parameters.Add(x => x.CancelText, "Cancel");

        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Task", parameters);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        try
        {
            await Mediator.Send(new DeleteTaskCommand(Id, _userId));
            Snackbar.Add("Task deleted.", Severity.Success);
            Navigation.NavigateTo("/tasks");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenAddSubTaskDialogAsync()
    {
        var parameters = new DialogParameters<SubTaskDialog>();
        parameters.Add(d => d.TaskItemId, Id);

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog  = await DialogService.ShowAsync<SubTaskDialog>("Add Subtask", parameters, options);
        var result  = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadDataAsync();
            StateHasChanged();
        }
    }

    // When all subtasks are checked off, prompts the user to also complete the parent task
    private async Task ToggleSubTaskAsync(SubTaskDto subtask, bool completed)
    {
        try
        {
            await Mediator.Send(new UpdateSubTaskCommand(
                subtask.Id, subtask.Title, subtask.Description, completed));
            await LoadDataAsync();

            if (_task is not null
                && _subTasks.Any()
                && _subTasks.All(s => s.IsCompleted)
                && _task.Status != WorkTaskStatus.Completed
                && _task.Status != WorkTaskStatus.Cancelled)
            {
                await PromptCompleteTaskAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task PromptCompleteTaskAsync()
    {
        var parameters = new DialogParameters<MudMessageBox>();
        parameters.Add(x => x.Message, "All subtasks are done. Would you like to mark this task as Completed?");
        parameters.Add(x => x.YesText, "Complete Task");
        parameters.Add(x => x.CancelText, "Not yet");

        var dialog = await DialogService.ShowAsync<MudMessageBox>("All subtasks completed! 🎉", parameters);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        await CompleteTaskWithMilestoneCheckAsync();
    }

    // If there are pending milestones, shows PendingMilestonesDialog first.
    // User can optionally complete them, then task is marked Completed regardless.
    private async Task CompleteTaskWithMilestoneCheckAsync()
    {
        var pendingMilestones = _milestones
            .Where(m => m.Status != MilestoneStatus.Completed)
            .ToList();

        bool markMilestones = false;

        if (pendingMilestones.Count > 0)
        {
            var dlgParams  = new DialogParameters<PendingMilestonesDialog>();
            dlgParams.Add(d => d.PendingCount, pendingMilestones.Count);

            var dlgOptions = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
            var dlg        = await DialogService.ShowAsync<PendingMilestonesDialog>("Pending Milestones", dlgParams, dlgOptions);
            var dlgResult  = await dlg.Result;

            if (dlgResult is null || dlgResult.Canceled) return;

            markMilestones = dlgResult.Data is bool b && b;
        }

        try
        {
            if (markMilestones)
            {
                foreach (var milestone in pendingMilestones)
                {
                    await Mediator.Send(new UpdateMilestoneCommand(
                        milestone.Id, milestone.Title, milestone.Description,
                        milestone.TargetDate, MilestoneStatus.Completed));
                }
            }

            await Mediator.Send(new UpdateTaskCommand(
                Id, _task!.Title, _task.Description, _task.DueDate, _task.Priority,
                WorkTaskStatus.Completed));

            Snackbar.Add(markMilestones
                ? "Task and all milestones marked as completed!"
                : "Task marked as completed!", Severity.Success);

            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    // Called after TaskDialog saves Completed status — task is already persisted,
    // so this only offers to complete any pending milestones (no second UpdateTaskCommand)
    private async Task HandlePendingMilestonesAfterCompletionAsync()
    {
        var pendingMilestones = _milestones
            .Where(m => m.Status != MilestoneStatus.Completed)
            .ToList();

        if (pendingMilestones.Count == 0) return;

        var parameters = new DialogParameters<PendingMilestonesDialog>();
        parameters.Add(d => d.PendingCount, pendingMilestones.Count);

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog  = await DialogService.ShowAsync<PendingMilestonesDialog>("Pending Milestones", parameters, options);
        var result  = await dialog.Result;

        if (result is null || result.Canceled) return;

        bool markMilestones = result.Data is bool b && b;
        if (!markMilestones) return;

        try
        {
            foreach (var milestone in pendingMilestones)
            {
                await Mediator.Send(new UpdateMilestoneCommand(
                    milestone.Id, milestone.Title, milestone.Description,
                    milestone.TargetDate, MilestoneStatus.Completed));
            }
            Snackbar.Add("All milestones marked as completed!", Severity.Success);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteSubTaskAsync(SubTaskDto subtask)
    {
        var parameters = new DialogParameters<MudMessageBox>();
        parameters.Add(x => x.Message, $"Delete subtask \"{subtask.Title}\"?");
        parameters.Add(x => x.YesText, "Delete");
        parameters.Add(x => x.CancelText, "Cancel");

        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Subtask", parameters);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        try
        {
            await Mediator.Send(new DeleteSubTaskCommand(subtask.Id));
            Snackbar.Add("Subtask deleted.", Severity.Success);
            await LoadDataAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenAddMilestoneDialogAsync()
    {
        var parameters = new DialogParameters<MilestoneDialog>();
        parameters.Add(d => d.TaskItemId, Id);

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog  = await DialogService.ShowAsync<MilestoneDialog>("Add Milestone", parameters, options);
        var result  = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadDataAsync();
            StateHasChanged();
        }
    }

    private async Task OpenEditMilestoneDialogAsync(MilestoneDto milestone)
    {
        var parameters = new DialogParameters<MilestoneDialog>();
        parameters.Add(d => d.TaskItemId, Id);
        parameters.Add(d => d.ExistingMilestone, milestone);

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog  = await DialogService.ShowAsync<MilestoneDialog>("Edit Milestone", parameters, options);
        var result  = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadDataAsync();
            StateHasChanged();
        }
    }

    private async Task DeleteMilestoneAsync(MilestoneDto milestone)
    {
        var parameters = new DialogParameters<MudMessageBox>();
        parameters.Add(x => x.Message, $"Delete milestone \"{milestone.Title}\"?");
        parameters.Add(x => x.YesText, "Delete");
        parameters.Add(x => x.CancelText, "Cancel");

        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Milestone", parameters);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        try
        {
            await Mediator.Send(new DeleteMilestoneCommand(milestone.Id));
            Snackbar.Add("Milestone deleted.", Severity.Success);
            await LoadDataAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private static Color GetPriorityColor(TaskPriority priority) => priority switch
    {
        TaskPriority.Low      => Color.Success,
        TaskPriority.Medium   => Color.Info,
        TaskPriority.High     => Color.Warning,
        TaskPriority.Critical => Color.Error,
        _                     => Color.Default
    };

    private static Color GetStatusColor(WorkTaskStatus status) => status switch
    {
        WorkTaskStatus.Pending    => Color.Default,
        WorkTaskStatus.InProgress => Color.Info,
        WorkTaskStatus.Completed  => Color.Success,
        WorkTaskStatus.Cancelled  => Color.Error,
        _                         => Color.Default
    };

    private static Color GetMilestoneStatusColor(MilestoneStatus status) => status switch
    {
        MilestoneStatus.Pending    => Color.Default,
        MilestoneStatus.InProgress => Color.Info,
        MilestoneStatus.Completed  => Color.Success,
        MilestoneStatus.Overdue    => Color.Error,
        _                          => Color.Default
    };

    private static string FormatStatus(WorkTaskStatus status) => status switch
    {
        WorkTaskStatus.InProgress => "In Progress",
        _                         => status.ToString()
    };
}
