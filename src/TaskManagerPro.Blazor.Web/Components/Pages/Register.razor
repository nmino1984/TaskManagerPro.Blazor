@page "/register"
@layout EmptyLayout
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using TaskManagerPro.Blazor.Web.Services

@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Create Account — TaskManager Pro</PageTitle>

<div class="auth-container">
    <MudCard Elevation="6" Class="auth-card">

        <MudCardContent>
            <div class="auth-logo">TaskManager Pro</div>
            <MudText Typo="Typo.body2" Align="Align.Center" Class="auth-subtitle">
                Create your free account
            </MudText>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true" ShowCloseIcon="true"
                          CloseIconClicked="() => _errorMessage = string.Empty">
                    @_errorMessage
                </MudAlert>
            }

            @if (_registrationSuccess)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4" Dense="true">
                    Account created successfully! You can now
                    <MudLink Href="/login" Color="Color.Success">sign in</MudLink>.
                </MudAlert>
            }

            <EditForm Model="_model" OnValidSubmit="RegisterAsync">
                <DataAnnotationsValidator />

                <MudGrid Spacing="2" Class="mb-1">
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string"
                                      Label="First Name"
                                      @bind-Value="_model.FirstName"
                                      For="() => _model.FirstName"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Person"
                                      AdornmentColor="Color.Primary"
                                      Variant="Variant.Outlined"
                                      Disabled="_isLoading"
                                      autocomplete="given-name" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string"
                                      Label="Last Name"
                                      @bind-Value="_model.LastName"
                                      For="() => _model.LastName"
                                      Variant="Variant.Outlined"
                                      Disabled="_isLoading"
                                      autocomplete="family-name" />
                    </MudItem>
                </MudGrid>

                <MudTextField T="string"
                              Label="Email"
                              @bind-Value="_model.Email"
                              For="() => _model.Email"
                              InputType="InputType.Email"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              AdornmentColor="Color.Primary"
                              Variant="Variant.Outlined"
                              Class="mt-3 mb-3"
                              Disabled="_isLoading"
                              autocomplete="email" />

                <MudTextField T="string"
                              Label="Password"
                              @bind-Value="_model.Password"
                              For="() => _model.Password"
                              InputType="_showPassword ? InputType.Text : InputType.Password"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="() => _showPassword = !_showPassword"
                              AdornmentAriaLabel="Toggle password visibility"
                              Variant="Variant.Outlined"
                              Class="mb-3"
                              Disabled="_isLoading"
                              autocomplete="new-password" />

                <MudTextField T="string"
                              Label="Confirm Password"
                              @bind-Value="_model.ConfirmPassword"
                              For="() => _model.ConfirmPassword"
                              InputType="_showConfirm ? InputType.Text : InputType.Password"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showConfirm ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="() => _showConfirm = !_showConfirm"
                              AdornmentAriaLabel="Toggle confirm password visibility"
                              Variant="Variant.Outlined"
                              Class="mb-5"
                              Disabled="_isLoading"
                              autocomplete="new-password" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="_isLoading || _registrationSuccess">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Creating account…</span>
                    }
                    else
                    {
                        <span>Create Account</span>
                    }
                </MudButton>
            </EditForm>
        </MudCardContent>

        <MudCardActions Class="justify-center pb-4">
            <MudText Typo="Typo.body2">
                Already have an account?
                <MudLink Href="/login" Color="Color.Primary">Sign In</MudLink>
            </MudText>
        </MudCardActions>

    </MudCard>
</div>

@code {
    private sealed class RegisterModel
    {
        [Required(ErrorMessage = "First name is required.")]
        [MaxLength(100, ErrorMessage = "First name must not exceed 100 characters.")]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Last name is required.")]
        [MaxLength(100, ErrorMessage = "Last name must not exceed 100 characters.")]
        public string LastName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        [RegularExpression(@"^(?=.*[A-Z])(?=.*\d).+$",
            ErrorMessage = "Password must contain at least one uppercase letter and one number.")]
        public string Password { get; set; } = string.Empty;

        // [Compare] handles the match check — no manual comparison needed in code
        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    private readonly RegisterModel _model = new();
    private bool _isLoading;
    private bool _showPassword;
    private bool _showConfirm;
    private string _errorMessage = string.Empty;
    private bool _registrationSuccess;

    private async Task RegisterAsync()
    {
        _isLoading = true;
        _errorMessage = string.Empty;

        try
        {
            await AuthService.RegisterAsync(_model.FirstName, _model.LastName, _model.Email, _model.Password);
            _registrationSuccess = true;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
