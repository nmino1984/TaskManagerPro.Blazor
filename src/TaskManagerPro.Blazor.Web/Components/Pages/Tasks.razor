@page "/tasks"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>My Tasks — TaskManager Pro</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
    <MudText Typo="Typo.h4">My Tasks</MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add">
        New Task
    </MudButton>
</MudStack>

<MudPaper Elevation="2" Class="pa-4">
    <MudText Color="Color.Secondary">No tasks found. Create your first task to get started.</MudText>
</MudPaper>
