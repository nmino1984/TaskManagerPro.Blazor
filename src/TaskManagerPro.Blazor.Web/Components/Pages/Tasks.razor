@page "/tasks"
@rendermode InteractiveServer
@inherits TaskManagerPro.Blazor.Web.Pages.AuthenticatedPageBase

@using MediatR
@using System.Security.Claims
@using TaskManagerPro.Blazor.Application.Features.Tasks.Queries.GetAllTasks
@using TaskManagerPro.Blazor.Application.Features.Tasks.Commands.DeleteTask
@using TaskManagerPro.Blazor.Application.Common.Models
@using TaskManagerPro.Blazor.Domain.Enums
@using TaskManagerPro.Blazor.Web.Components.Dialogs

@inject IMediator Mediator
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>My Tasks — TaskManager Pro</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">My Tasks</MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreateDialogAsync">
        New Task
    </MudButton>
</MudStack>

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="7" md="8">
            <MudTextField T="string"
                          @bind-Value="_searchTitle"
                          Label="Search by title"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined"
                          Clearable="true"
                          Immediate="true"
                          DebounceInterval="300"
                          OnDebounceIntervalElapsed="ApplyFilters" />
        </MudItem>
        <MudItem xs="12" sm="5" md="4">
            <MudSelect T="WorkTaskStatus?"
                       Value="_filterStatus"
                       ValueChanged="OnStatusFilterChanged"
                       Label="Filter by status"
                       Variant="Variant.Outlined"
                       Clearable="true">
                <MudSelectItem T="WorkTaskStatus?" Value="null">All statuses</MudSelectItem>
                @foreach (WorkTaskStatus s in Enum.GetValues<WorkTaskStatus>())
                {
                    <MudSelectItem T="WorkTaskStatus?" Value="s">@FormatStatus(s)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_errorMessage != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
}

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
}

@if (_filteredTasks.Any())
{
    <MudTable Items="_filteredTasks"
              Elevation="2"
              Hover="true"
              Dense="false"
              Loading="_isLoading">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<TaskItemDto, object>(x => x.Title)">Title</MudTableSortLabel></MudTh>
            <MudTh>Priority</MudTh>
            <MudTh>Status</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TaskItemDto, object>(x => x.DueDate ?? DateTime.MaxValue)">Due Date</MudTableSortLabel></MudTh>
            <MudTh Style="width:120px">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">
                <MudLink Href="@($"/tasks/{context.Id}")"
                         Typo="Typo.body2"
                         Style="font-weight:500; cursor:pointer">
                    @context.Title
                </MudLink>
            </MudTd>
            <MudTd DataLabel="Priority">
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@GetPriorityColor(context.Priority)"
                         Variant="Variant.Filled">
                    @context.Priority
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@GetStatusColor(context.Status)"
                         Variant="Variant.Outlined">
                    @FormatStatus(context.Status)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Due Date">
                @if (context.DueDate.HasValue)
                {
                    bool overdue = context.DueDate.HasValue
                                   && context.DueDate.Value.Date < DateTime.UtcNow.Date
                                   && context.Status != WorkTaskStatus.Completed
                                   && context.Status != WorkTaskStatus.Cancelled;
                    <MudText Typo="Typo.body2" Color="@(overdue ? Color.Error : Color.Default)">
                        @context.DueDate.Value.ToString("MMM dd, yyyy")
                        @if (overdue) { <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="ml-1" /> }
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                }
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Size="Size.Small"
                               Color="Color.Primary"
                               aria-label="Edit task"
                               OnClick="() => OpenEditDialogAsync(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Size="Size.Small"
                               Color="Color.Error"
                               aria-label="Delete task"
                               OnClick="() => DeleteTaskAsync(context)" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }" />
        </PagerContent>
    </MudTable>
}
else if (!_isLoading)
{
    <MudPaper Elevation="2" Class="pa-8 d-flex align-center justify-center">
        <MudStack AlignItems="AlignItems.Center" Spacing="3">
            <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn"
                     Size="Size.Large" Color="Color.Secondary" />
            <MudText Color="Color.Secondary">
                @(_searchTitle.Length > 0 || _filterStatus.HasValue
                    ? "No tasks match your filters."
                    : "No tasks found. Create your first task!")
            </MudText>
            @if (_searchTitle.Length == 0 && !_filterStatus.HasValue)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenCreateDialogAsync">
                    New Task
                </MudButton>
            }
        </MudStack>
    </MudPaper>
}

@code {
    private IList<TaskItemDto> _allTasks      = new List<TaskItemDto>();
    private IList<TaskItemDto> _filteredTasks = new List<TaskItemDto>();
    private Guid _userId;
    private bool _isLoading = true;
    private string _searchTitle = string.Empty;
    private WorkTaskStatus? _filterStatus;
    private string? _errorMessage;

    // OnInitializedAsync runs during SSR where localStorage is inaccessible and "sub" claim is null;
    // firstRender is the first safe point after the Blazor Server circuit is fully connected
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState    = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdString = authState.User.FindFirst("sub")?.Value;

        if (string.IsNullOrEmpty(userIdString) || !Guid.TryParse(userIdString, out Guid userId))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _userId = userId;
        await LoadTasksAsync();
        StateHasChanged();
    }

    private async Task LoadTasksAsync()
    {
        _isLoading = true;
        try
        {
            var result = await Mediator.Send(new GetAllTasksQuery(_userId, Page: 1, PageSize: 1000));
            _allTasks = result.Items;
            ApplyFilters();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message + " | " + ex.InnerException?.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        _filteredTasks = _allTasks
            .Where(t => string.IsNullOrWhiteSpace(_searchTitle)
                        || t.Title.Contains(_searchTitle, StringComparison.OrdinalIgnoreCase))
            .Where(t => _filterStatus is null || t.Status == _filterStatus)
            .OrderByDescending(t => t.CreatedAt)
            .ToList();
    }

    private async Task OpenCreateDialogAsync()
    {
        var parameters = new DialogParameters<TaskDialog>();
        parameters.Add(d => d.UserId, _userId);
        parameters.Add(d => d.ExistingTask, null);

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog  = await DialogService.ShowAsync<TaskDialog>("New Task", parameters, options);
        var result  = await dialog.Result;

        if (result is { Canceled: false })
            await LoadTasksAsync();
    }

    private async Task OpenEditDialogAsync(TaskItemDto task)
    {
        var parameters = new DialogParameters<TaskDialog>();
        parameters.Add(d => d.UserId, _userId);
        parameters.Add(d => d.ExistingTask, task);

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog  = await DialogService.ShowAsync<TaskDialog>("Edit Task", parameters, options);
        var result  = await dialog.Result;

        if (result is { Canceled: false })
            await LoadTasksAsync();
    }

    private void OnStatusFilterChanged(WorkTaskStatus? value)
    {
        _filterStatus = value;
        ApplyFilters();
    }

    private async Task DeleteTaskAsync(TaskItemDto task)
    {
        var parameters = new DialogParameters<MudMessageBox>();
        parameters.Add(x => x.Message, $"Are you sure you want to delete \"{task.Title}\"? This action cannot be undone.");
        parameters.Add(x => x.YesText, "Delete");
        parameters.Add(x => x.CancelText, "Cancel");

        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Task", parameters);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        try
        {
            await Mediator.Send(new DeleteTaskCommand(task.Id, _userId));
            Snackbar.Add("Task deleted.", Severity.Success);
            await LoadTasksAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private static Color GetPriorityColor(TaskPriority p) => p switch
    {
        TaskPriority.Low      => Color.Success,
        TaskPriority.Medium   => Color.Info,
        TaskPriority.High     => Color.Warning,
        TaskPriority.Critical => Color.Error,
        _                     => Color.Default
    };

    private static Color GetStatusColor(WorkTaskStatus s) => s switch
    {
        WorkTaskStatus.Pending    => Color.Default,
        WorkTaskStatus.InProgress => Color.Info,
        WorkTaskStatus.Completed  => Color.Success,
        WorkTaskStatus.Cancelled  => Color.Error,
        _                         => Color.Default
    };

    private static string FormatStatus(WorkTaskStatus s) => s switch
    {
        WorkTaskStatus.InProgress => "In Progress",
        _                         => s.ToString()
    };
}
