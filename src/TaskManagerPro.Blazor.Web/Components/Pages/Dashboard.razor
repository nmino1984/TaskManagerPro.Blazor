@page "/"
@rendermode InteractiveServer
@inherits TaskManagerPro.Blazor.Web.Pages.AuthenticatedPageBase

@using MediatR
@using System.Security.Claims
@using TaskManagerPro.Blazor.Application.Features.Tasks.Queries.GetAllTasks
@using TaskManagerPro.Blazor.Application.Common.Models
@using TaskManagerPro.Blazor.Domain.Enums

@inject IMediator Mediator

<PageTitle>Dashboard — TaskManager Pro</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-6" Color="Color.Secondary">
    Welcome back. Here is an overview of your tasks.
</MudText>

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-6" />
}

<MudGrid Spacing="3" Class="mb-8">
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <div>
                    <MudText Typo="Typo.overline" Color="Color.Secondary">My Tasks</MudText>
                    <MudText Typo="Typo.h4">@_totalTasks</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" Size="Size.Large" />
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <div>
                    <MudText Typo="Typo.overline" Color="Color.Secondary">In Progress</MudText>
                    <MudText Typo="Typo.h4">@_inProgressCount</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Color="Color.Info" Size="Size.Large" />
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <div>
                    <MudText Typo="Typo.overline" Color="Color.Secondary">Completed</MudText>
                    <MudText Typo="Typo.h4">@_completedCount</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <div>
                    <MudText Typo="Typo.overline" Color="Color.Secondary">Overdue</MudText>
                    <MudText Typo="Typo.h4" Color="@(_overdueCount > 0 ? Color.Error : Color.Default)">
                        @_overdueCount
                    </MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Large" />
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@* Charts *@
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="0">
    <MudText Typo="Typo.h6" Class="mr-4">Charts</MudText>
    <MudButtonGroup OverrideStyles="false">
        <MudButton Variant="@(!_showAllTasks ? Variant.Filled : Variant.Outlined)"
                   Color="Color.Primary" Size="Size.Small"
                   OnClick="@(() => SwitchChartFilter(false))">
            My Tasks
        </MudButton>
        <MudButton Variant="@(_showAllTasks ? Variant.Filled : Variant.Outlined)"
                   Color="Color.Primary" Size="Size.Small"
                   OnClick="@(() => SwitchChartFilter(true))">
            All Tasks
        </MudButton>
    </MudButtonGroup>
</MudStack>

<MudGrid Spacing="3" Class="mb-6">
    <MudItem xs="12" md="6">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Tasks by Status</MudText>
            <MudChart T="double" ChartType="ChartType.Donut"
                      ChartSeries="@_statusSeries"
                      ChartLabels="@_statusLabels"
                      Width="100%" Height="300px"
                      ChartOptions="@_statusOptions" />
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Tasks by Priority</MudText>
            <MudChart T="double" ChartType="ChartType.Bar"
                      ChartSeries="@_prioritySeries"
                      ChartLabels="@_priorityLabels"
                      Width="100%" Height="300px"
                      ChartOptions="@_priorityOptions" />
        </MudPaper>
    </MudItem>
</MudGrid>

@if (_showMonthChart)
{
    <MudPaper Elevation="2" Class="pa-4 mb-6">
        <MudText Typo="Typo.h6" Class="mb-3">Tasks Created (last 6 months)</MudText>
        <MudChart T="double" ChartType="ChartType.Line"
                  ChartSeries="@_monthSeries"
                  ChartLabels="@_monthLabels"
                  Width="100%" Height="300px"
                  ChartOptions="@_monthOptions" />
    </MudPaper>
}

<MudText Typo="Typo.h6" Class="mb-3">Recent Tasks</MudText>

@if (_recentTasks.Any())
{
    <MudTable Items="_recentTasks" Elevation="2" Hover="true" Dense="false">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Priority</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Due Date</MudTh>
            <MudTh>Role</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">
                <MudText Typo="Typo.body2" Style="font-weight:500">@context.Title</MudText>
            </MudTd>
            <MudTd DataLabel="Priority">
                <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(context.Priority)" Variant="Variant.Filled">
                    @context.Priority
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Outlined">
                    @FormatStatus(context.Status)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Due Date">
                @if (context.DueDate.HasValue)
                {
                    <MudText Typo="Typo.body2"
                             Color="@(context.DueDate < DateTime.UtcNow && context.Status != WorkTaskStatus.Completed ? Color.Error : Color.Default)">
                        @context.DueDate.Value.ToString("MMM dd, yyyy")
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Role">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@GetTaskRole(context)</MudText>
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else if (!_isLoading)
{
    <MudPaper Elevation="2" Class="pa-6 d-flex align-center justify-center">
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Size="Size.Large" Color="Color.Secondary" />
            <MudText Color="Color.Secondary">No tasks found. Create your first task!</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/tasks"
                       StartIcon="@Icons.Material.Filled.Add" Size="Size.Small">
                Go to Tasks
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    private Guid _userId;
    private int _totalTasks;
    private int _inProgressCount;
    private int _completedCount;
    private int _overdueCount;
    private IList<TaskItemDto> _recentTasks = new List<TaskItemDto>();
    private IList<TaskItemDto> _allTasks    = new List<TaskItemDto>();
    private IList<TaskItemDto> _myTasks     = new List<TaskItemDto>();
    private bool _isLoading    = true;
    private bool _showAllTasks = false;

    private List<ChartSeries<double>> _statusSeries   = [];
    private string[]                  _statusLabels   = ["Pending", "In Progress", "Completed", "Cancelled"];
    private List<ChartSeries<double>> _prioritySeries = [];
    private string[]                  _priorityLabels = ["Low", "Medium", "High", "Critical"];
    private List<ChartSeries<double>> _monthSeries    = [];
    private string[]                  _monthLabels    = [];
    private bool                      _showMonthChart;

    private readonly ChartOptions _statusOptions = new()
    {
        ChartPalette = ["#2196F3", "#FF9800", "#4CAF50", "#9E9E9E"]
    };
    private readonly ChartOptions _priorityOptions = new()
    {
        ChartPalette = ["#4CAF50", "#FFC107", "#FF9800", "#F44336"]
    };
    private readonly ChartOptions _monthOptions = new()
    {
        ChartPalette = ["#2196F3"]
    };

    // OnInitializedAsync runs during SSR where localStorage is inaccessible and `sub` claim is null;
    // firstRender is the first safe point after the Blazor Server circuit is fully connected
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState    = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdString = authState.User.FindFirst("sub")?.Value;

        if (string.IsNullOrEmpty(userIdString) || !Guid.TryParse(userIdString, out Guid userId))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _userId = userId;

        try
        {
            var result = await Mediator.Send(new GetAllTasksQuery(userId, Page: 1, PageSize: 1000));
            _allTasks  = result.Items;
            _myTasks   = _allTasks.Where(t => t.AssignedToUserId == userId).ToList();

            _totalTasks      = _myTasks.Count;
            _inProgressCount = _myTasks.Count(t => t.Status == WorkTaskStatus.InProgress);
            _completedCount  = _myTasks.Count(t => t.Status == WorkTaskStatus.Completed);
            _overdueCount    = _myTasks.Count(t =>
                t.DueDate.HasValue
                && t.DueDate.Value.Date < DateTime.UtcNow.Date
                && t.Status != WorkTaskStatus.Completed
                && t.Status != WorkTaskStatus.Cancelled);

            _recentTasks = _allTasks.OrderByDescending(t => t.CreatedAt).Take(5).ToList();

            BuildCharts(_myTasks);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void SwitchChartFilter(bool showAll)
    {
        _showAllTasks = showAll;
        BuildCharts(_showAllTasks ? _allTasks : _myTasks);
        StateHasChanged();
    }

    private void BuildCharts(IList<TaskItemDto> tasks)
    {
        _statusSeries =
        [
            new ChartSeries<double>
            {
                Name = "Status",
                Data = new ChartData<double>(new double[]
                {
                    (double)tasks.Count(t => t.Status == WorkTaskStatus.Pending),
                    (double)tasks.Count(t => t.Status == WorkTaskStatus.InProgress),
                    (double)tasks.Count(t => t.Status == WorkTaskStatus.Completed),
                    (double)tasks.Count(t => t.Status == WorkTaskStatus.Cancelled)
                })
            }
        ];

        _prioritySeries =
        [
            new ChartSeries<double>
            {
                Name = "Tasks",
                Data = new ChartData<double>(new double[]
                {
                    (double)tasks.Count(t => t.Priority == TaskPriority.Low),
                    (double)tasks.Count(t => t.Priority == TaskPriority.Medium),
                    (double)tasks.Count(t => t.Priority == TaskPriority.High),
                    (double)tasks.Count(t => t.Priority == TaskPriority.Critical)
                })
            }
        ];

        var now    = DateTime.UtcNow;
        var months = Enumerable.Range(0, 6).Select(i => now.AddMonths(-5 + i)).ToList();

        _monthLabels = months.Select(m => m.ToString("MMM yy")).ToArray();
        double[] monthlyCounts = months
            .Select(m => (double)tasks.Count(t => t.CreatedAt.Year == m.Year && t.CreatedAt.Month == m.Month))
            .ToArray();

        _monthSeries    = [new ChartSeries<double> { Name = "Created", Data = new ChartData<double>(monthlyCounts) }];
        _showMonthChart = months.Count(m => tasks.Any(t => t.CreatedAt.Year == m.Year && t.CreatedAt.Month == m.Month)) >= 2;
    }

    private string GetTaskRole(TaskItemDto task)
    {
        bool isAssigned = task.AssignedToUserId == _userId;
        bool isCreator  = task.UserId == _userId;

        if (isAssigned && isCreator) return "Mine";
        if (isAssigned)              return "Assigned to me";
        if (isCreator)               return "Created by me";
        return "—";
    }

    private static Color GetPriorityColor(TaskPriority priority) => priority switch
    {
        TaskPriority.Low      => Color.Success,
        TaskPriority.Medium   => Color.Info,
        TaskPriority.High     => Color.Warning,
        TaskPriority.Critical => Color.Error,
        _                     => Color.Default
    };

    private static Color GetStatusColor(WorkTaskStatus status) => status switch
    {
        WorkTaskStatus.Pending    => Color.Default,
        WorkTaskStatus.InProgress => Color.Info,
        WorkTaskStatus.Completed  => Color.Success,
        WorkTaskStatus.Cancelled  => Color.Error,
        _                         => Color.Default
    };

    private static string FormatStatus(WorkTaskStatus status) => status switch
    {
        WorkTaskStatus.InProgress => "In Progress",
        _                         => status.ToString()
    };
}